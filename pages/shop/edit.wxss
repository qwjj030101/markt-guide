/* 商铺编辑页面样式 */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
  padding: 0 30rpx;
  background-color: #fff;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-left, .nav-right {
  width: 80rpx;
}

.nav-left text {
  font-size: 30rpx;
  color: #666;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.submit-btn {
  font-size: 30rpx;
  color: #3cc51f;
  font-weight: 500;
}

/* 表单容器 */
.form-container {
  padding: 30rpx 30rpx 50rpx;
  background-color: #f5f5f5;
}

/* 表单项 */
.form-item {
  background-color: #fff;
  margin-bottom: 20rpx;
  padding: 30rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.label {
  display: block;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  font-weight: 500;
}

/* 输入框 */
.input {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.input:focus {
  border-bottom-color: #3cc51f;
}

/* 地址输入框 */
.address-input {
  position: relative;
}

.address-input .input {
  padding-right: 60rpx;
}

.address-icon {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  font-size: 30rpx;
}

/* 文本域 */
.textarea {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  min-height: 120rpx;
}

.textarea:focus {
  border-bottom-color: #3cc51f;
}

/* 头像上传 */
.avatar-upload {
  display: flex;
  align-items: center;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  margin-right: 30rpx;
  border: 2rpx solid #f0f0f0;
}

.upload-btn {
  padding: 15rpx 30rpx;
  background-color: #f5f5f5;
  border-radius: 50rpx;
  font-size: 26rpx;
  color: #666;
}

.upload-btn:hover {
  background-color: #e8e8e8;
}

/* 响应式布局 */
@media (max-width: 375px) {
  .form-container {
    padding: 20rpx 20rpx 40rpx;
  }
  
  .form-item {
    padding: 20rpx;
  }
  
  .avatar {
    width: 120rpx;
    height: 120rpx;
  }
  
  .nav-bar {
    padding: 0 20rpx;
  }
}
<view class="container">
  <swiper-ad banners="{{banners}}" bind:adTap="onAdTap"></swiper-ad>
  
  <!-- 商户订阅消息授权按钮 -->
  <view wx:if="{{isMerchant}}" class="subscribe-btn-container">
    <view class="subscribe-btn" bindtap="onSubscribeTap">
      <text>订阅新需求通知</text>
    </view>
  </view>
  
  <view class="page-title">{{pageTitle}}</view>
  <view class="demand-list">
     <demand-card 
      wx:for="{{demandList}}" 
      wx:key="id" 
      demand="{{item}}" 
      userQuota="{{userQuota}}" 
      userPackageExpire="{{userPackageExpire}}" 
      bind:tapShop="onTapShop" 
      bind:tapResponse="onTapResponse" 
      bind:tapComplete="onTapComplete" 
      bind:tapWithdraw="onDemandWithdraw"
      bind:needBuy="onNeedBuy"
      bind:tapCard="onDemandCardTap"
    />
  </view>
  <view class="publish-btn"  bindtap="onPublish">
    <text>发布需求</text>
  </view>
</view>
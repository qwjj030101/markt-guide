.container {
  height: 100vh;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-content {
  width: 80%;
  max-height: 80%;
  background-color: #fff;
  border-radius: 10rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-align: center;
}

.content {
  flex: 1;
  margin-bottom: 20rpx;
  overflow-y: auto;
}

.content-text {
  font-size: 24rpx;
  line-height: 40rpx;
  color: #333;
}

.buttons {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
}

.reject-btn, .accept-btn {
  width: 300rpx;
  height: 80rpx;
  font-size: 28rpx;
}

.reject-btn {
  border-color: #999;
  color: #666;
}

.accept-btn {
  background-color: #07c160;
  color: #fff;
}
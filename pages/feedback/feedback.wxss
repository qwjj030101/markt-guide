.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  text-align: center;
  margin: 30rpx 0;
  color: #333;
}

.form-item {
  background-color: white;
  border-radius: 10rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.input {
  font-size: 28rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.textarea {
  font-size: 28rpx;
  padding: 20rpx;
  border: 1rpx solid #eee;
  border-radius: 5rpx;
  min-height: 200rpx;
  resize: none;
}

.count {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  margin-top: 10rpx;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}

.upload-container {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
  position: relative;
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 5rpx;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: rgba(0, 0, 0, 0.5);
  color: white;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 5rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 60rpx;
  color: #999;
}

.submit-btn {
  background-color: #3cc51f;
  color: white;
  font-size: 32rpx;
  padding: 30rpx;
  border-radius: 10rpx;
  margin-top: 30rpx;
  margin-bottom: 50rpx;
}

.submit-btn:disabled {
  background-color: #ccc;
  color: #fff;
}
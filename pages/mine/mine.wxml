<view class="container">
  <!-- 顶部用户信息区域 -->
  <view class="user-info">
    <!-- 未授权时显示授权引导 -->
    <view wx:if="{{!isAuthorized}}" class="authorize-guide">
      <text class="guide-text">授权后可查看个人信息、管理商铺等</text>
      <view class="authorize-btn" bindtap="onAuthorizeTap">
        <text>去授权</text>
      </view>
    </view>
    <!-- 已授权时显示用户信息 -->
    <view wx:else class="user-info-container">
      <!-- 更多操作按钮 -->
      <view class="more-btn" bindtap="showActionSheet">
        <text>...</text>
      </view>
      <view class="user-avatar-container">
        <image class="user-avatar" src="{{userInfo.avatarUrl || 'https://via.placeholder.com/100'}}" mode="aspectFill"></image>
      </view>
      <view class="user-nickname-container">
        <text class="user-nickname">{{userInfo.nickName}}</text>
        <text class="user-days" wx:if="{{isMerchant && isValid}}">店铺到期时间：{{expireDateFormatted}}</text>
        <text class="user-days" wx:if="{{isMerchant}}">剩余响应次数：{{responseQuota}}</text>
        <text class="user-days" wx:if="{{isMerchant && responsePackageExpire}}">响应到期时间：{{responsePackageExpire}}</text>
      </view>
    </view>
  </view>
  
  <!-- 下方按钮区域 -->
  <view class="action-buttons">
    <!-- 我的店铺按钮 -->
    <view class="btn-shop" bindtap="onShopTap">
      <text class="btn-text">我的店铺</text>
    </view>
    
    <!-- 根据角色显示不同按钮 -->
    <view wx:if="{{isMerchant && isValid}}" class="btn-renew" bindtap="onRenewTap">
      <text>续费</text>
    </view>
    <view wx:else class="btn-join" bindtap="onJoinTap">
      <text>入驻平台</text>
    </view>
    
    <!-- 购买响应包按钮 -->
    <view wx:if="{{isMerchant}}" class="btn-buy" bindtap="onBuyTap">
      <text>购买响应包</text>
    </view>
  </view>
</view>
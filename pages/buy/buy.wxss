.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 20rpx;
}

.header {
  text-align: center;
  margin: 40rpx 0;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.package-section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 4rpx solid #3cc51f;
}

.package-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.package-item {
  width: 48%;
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
  position: relative;
  cursor: pointer;
  transition: all 0.3s ease;
}

.package-item:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.package-info {
  margin-bottom: 15rpx;
}

.package-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
}

.package-desc {
  font-size: 20rpx;
  color: #666;
  display: block;
  line-height: 1.4;
}

.package-price {
  text-align: right;
}

.price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4d4f;
  display: block;
}

.unit-price {
  font-size: 18rpx;
  color: #999;
  display: block;
}

.package-select {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background-color: #3cc51f;
  color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 20rpx;
}

.custom-package {
  border: 2rpx dashed #3cc51f;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #fff;
  padding: 20rpx;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.selected-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.selected-price {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.buy-container {
  display: flex;
  align-items: center;
  position: relative;
}

.price-info {
  flex: 1;
  display: flex;
  align-items: center;
  margin-right: 20rpx;
}

.buy-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #3cc51f;
  color: #fff;
  font-size: 32rpx;
  border-radius: 10rpx;
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
}

.price-info {
  display: flex;
  align-items: center;
}

.price-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 10rpx;
}

.price-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d4f;
  margin-right: 10rpx;
}

.package-info-text {
  font-size: 20rpx;
  color: #999;
}

.buy-btn {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #3cc51f;
  color: #fff;
  font-size: 32rpx;
  border-radius: 10rpx;
}

.buy-btn::after {
  border: none;
}

.buy-btn:disabled {
  background-color: #95de64;
  color: #fff;
}
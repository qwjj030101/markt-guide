<view class="container">
  <view class="page-title">意见反馈</view>
  
  <form bindsubmit="onSubmit">
    <!-- 反馈类型 -->
    <view class="form-item">
      <text class="label">反馈类型</text>
      <picker mode="selector" range="{{feedbackTypes}}" bindchange="onTypeChange" value="{{selectedType}}">
        <view class="picker-value">{{feedbackTypes[selectedType]}}</view>
      </picker>
    </view>
    
    <!-- 标题 -->
    <view class="form-item">
      <text class="label">标题</text>
      <input 
        type="text" 
        placeholder="请填写标题" 
        name="title" 
        value="{{formData.title}}" 
        bindinput="onTitleInput"
        class="input"
      />
    </view>
    
    <!-- 内容 -->
    <view class="form-item">
      <text class="label">内容</text>
      <textarea 
        placeholder="请详细描述您的问题或建议" 
        name="content" 
        value="{{formData.content}}" 
        bindinput="onContentInput"
        class="textarea"
        maxlength="500"
      />
      <text class="count">{{formData.content.length}}/500</text>
    </view>
    
    <!-- 图片上传 -->
    <view class="form-item">
      <text class="label">图片上传（最多3张）</text>
      <view class="upload-container">
        <view 
          wx:for="{{imageList}}" 
          wx:key="index" 
          class="image-item"
        >
          <image src="{{item}}" mode="aspectFill" bindtap="previewImage" data-index="{{index}}"></image>
          <view class="delete-btn" bindtap="deleteImage" data-index="{{index}}">×</view>
        </view>
        <view 
          wx:if="{{imageList.length < 3}}" 
          class="upload-btn" 
          bindtap="chooseImage"
        >
          <text>+</text>
        </view>
      </view>
    </view>
    
    <!-- 联系方式 -->
    <view class="form-item">
      <text class="label">联系方式</text>
      <input 
        type="text" 
        placeholder="选填，手机号或微信号" 
        name="contact" 
        value="{{formData.contact}}" 
        bindinput="onContactInput"
        class="input"
      />
    </view>
    
    <!-- 提交按钮 -->
    <button 
      form-type="submit" 
      class="submit-btn" 
      disabled="{{!formData.title || !formData.content}}"
    >
      提交反馈
    </button>
  </form>
</view>
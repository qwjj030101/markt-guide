<view class="container">
  <!-- 顶部商铺名片 -->
  <view class="shop-card">
    <!-- 背景图 -->
    <view class="bg-image" style="background-image: url({{shopInfo.avatar || '/images/R.jpg'}});"></view>
    <view class="bg-blur"></view>
    <!-- 商铺信息 -->
    <view class="shop-info">
      <text class="shop-name">{{shopInfo.name}}</text>
      <view class="shop-details">
        <view class="detail-item" bindtap="onPhoneTap">
          <text class="detail-label">电话：</text>
          <text class="detail-value">{{shopInfo.phone}}</text>
        </view>
        <view class="detail-item" bindtap="onAddressTap">
          <text class="detail-label">地址：</text>
          <text class="detail-value">{{shopInfo.address}}</text>
        </view>
        <view class="detail-item">
          <text class="detail-label">营业时间：</text>
          <text class="detail-value">{{shopInfo.business_hours || shopInfo.businessHours || '09:00-18:00'}}</text>
        </view>
        <view class="detail-item">
          <text class="detail-label">商铺简介：</text>
          <text class="detail-value">{{shopInfo.description}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部商品列表 -->
  <view class="products-section">
    <text class="section-title">商品列表</text>
    <view class="products-grid">
      <block wx:for="{{productList}}" wx:key="_id">
        <view class="product-item">
          <view class="product-image">
            <image src="{{item.image || '/images/product1.jpg'}}" mode="aspectFill" binderror="onImageError"></image>
          </view>
          <text class="product-name">{{item.name}}</text>
        </view>
      </block>
      <block wx:if="{{productList.length === 0}}">
        <view class="empty-tip">
          <text>暂无商品</text>
        </view>
      </block>
    </view>
  </view>
</view>
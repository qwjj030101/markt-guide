/* 订阅消息授权按钮容器 */
.subscribe-btn-container {
  padding: 20rpx;
  margin-bottom: 20rpx;
}

/* 订阅消息授权按钮 */
.subscribe-btn {
  background-color: #3cc51f;
  color: white;
  border-radius: 10rpx;
  padding: 30rpx;
  font-size: 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 订阅消息授权按钮激活状态 */
.subscribe-btn:active {
  opacity: 0.8;
}.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

.banner {
  height: 300rpx;
  margin-bottom: 20rpx;
}

.banner swiper {
  width: 100%;
  height: 100%;
}

.banner image {
  width: 100%;
  height: 100%;
}

.page-title {
  padding: 20rpx 30rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.demand-list {
  padding: 20rpx;
}

.demand-item {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
}

.demand-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.user-nickname {
  font-size: 28rpx;
  color: #666;
}

.demand-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.response-list {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 20rpx;
}

.response-item {
  display: flex;
  align-items: center;
  margin-right: 20rpx;
  margin-bottom: 10rpx;
}

.response-avatar {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.response-remark {
  font-size: 24rpx;
  color: #999;
}

.more-response {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.demand-actions {
  display: flex;
  justify-content: flex-end;
}

.btn-complete,
.btn-respond {
  padding: 10rpx 30rpx;
  font-size: 28rpx;
  border-radius: 5rpx;
}

.btn-complete {
  background-color: #f0f0f0;
  color: #666;
}

.btn-respond {
  background-color: #3cc51f;
  color: #fff;
}

.publish-btn {
  position: fixed;
  bottom: 40rpx;
  right: 30rpx;
  width: 120rpx;
  height: 120rpx;
  background-color: #45dc75ff;
  border-radius: 50%;
  color: white;
  text-align: center;
  line-height: 120rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
  z-index: 100;
}
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.user-info {
  padding: 30rpx 0;
  text-align: left;
  background: linear-gradient(135deg, #4caf50 0%, #81c784 100%);
  color: white;
  border-bottom-left-radius: 30rpx;
  border-bottom-right-radius: 30rpx;
  margin-bottom: 30rpx;
}

/* 用户信息容器 */
.user-info-container {
  display: flex;
  align-items: center;
  padding: 0 40rpx;
  position: relative;
}

/* 更多操作按钮 */
.more-btn {
  position: absolute;
  top: 20rpx;
  right: 30rpx;
  font-size: 36rpx;
  color: white;
  cursor: pointer;
  z-index: 10;
}

/* 头像容器 */
.user-avatar-container {
  margin-right: 100rpx;
  position: relative;
}

/* 昵称容器 */
.user-nickname-container {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

/* 用户昵称 */
.user-nickname {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

/* 昵称编辑提示 */
.nickname-edit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  cursor: pointer;
}

.user-avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.user-nickname {
  font-size: 36rpx;
  color: white;
}

.action-buttons {
  padding: 20rpx;
}

.btn-shop,
.btn-renew,
.btn-join {
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  color: #333;
}

.btn-shop {
  flex-direction: column;
  background-color: #3cc51f;
  color: #fff;
}

.btn-shop .btn-text {
  font-size: 32rpx;
  margin-bottom: 10rpx;
}

.user-days {
  font-size: 24rpx;
  color: #ffffff;
  margin-top: 10rpx;
}

.btn-renew,
.btn-join {
  background-color: #3cc51f;
  color: #fff;
}
/* 授权引导样式 */
.authorize-guide {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 20rpx;
}

.guide-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 30rpx;
}

.authorize-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}
.publish-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.page-header {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e5e5e5;
}

.page-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.content-section {
  margin-bottom: 30rpx;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.section-label {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.content-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
  padding: 12rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 8rpx;
  background-color: #f9f9f9;
  resize: none;
}

.placeholder {
  color: #999;
}

.image-section {
  margin-bottom: 40rpx;
  background-color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.image-upload-area {
  margin-top: 12rpx;
}

.upload-btn {
  width: 100%;
  height: 200rpx;
  border: 2rpx dashed #e5e5e5;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #f9f9f9;
  color: #999;
}

.upload-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 24rpx;
}

.image-preview {
  position: relative;
  width: 100%;
  height: 200rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.image-preview image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.delete-btn {
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  background-color: rgba(0, 0, 0, 0.6);
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
}

.action-buttons {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  background-color: #fff;
  border-top: 1rpx solid #e5e5e5;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.btn-cancel,
.btn-publish {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin: 0 10rpx;
}

.btn-cancel {
  background-color: #f5f5f5;
  color: #666;
  border: 1rpx solid #e5e5e5;
}

.btn-publish {
  background-color: #2196F3;
  color: #fff;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .content-input {
    min-height: 150rpx;
  }
  
  .image-preview,
  .upload-btn {
    height: 180rpx;
  }
  
  .btn-cancel,
  .btn-publish {
    height: 70rpx;
    line-height: 70rpx;
    font-size: 26rpx;
  }
}
<view class="container">
  <!-- 顶部用户信息区域 -->
  <view class="user-info">
    <!-- 未授权时显示授权引导 -->
    <view wx:if="{{!isAuthorized}}" class="authorize-guide">
      <image class="default-avatar" src="/images/default-avatar.png" mode="aspectFill"></image>
      <text class="guide-text">点击下方按钮登录/授权</text>
      <text class="guide-subtext" wx:if="{{showReauthorize}}">您未授权，无法获取头像和昵称</text>
      <view class="authorize-btn" bindtap="onAuthorizeTap">
        <text>{{showReauthorize ? '重新授权' : '点击登录/授权'}}</text>
      </view>
    </view>
    <!-- 已授权时显示用户信息 -->
    <view wx:else class="user-info-container">
      <!-- 更多操作按钮 -->
      <view class="more-btn" bindtap="showActionSheet">
        <text>...</text>
      </view>
      <view class="user-avatar-container">
        <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill"></image>
      </view>
      <view class="user-nickname-container">
        <text class="user-nickname">{{userInfo.nickName}}</text>
        <text class="user-days" wx:if="{{isMerchant && isValid}}">店铺到期时间：{{expireDateFormatted}}</text>
        <text class="user-days" wx:if="{{isMerchant}}">响应次数：{{responseQuota}}次</text>
        <text class="user-days" wx:if="{{isMerchant && responsePackageExpire}}">响应到期时间：{{responsePackageExpire}}</text>
      </view>
    </view>
  </view>
  
  <!-- 下方按钮区域 -->
  <view class="action-buttons">
    <!-- 第一行按钮 -->
    <view class="button-row">
      <!-- 我的店铺按钮 -->
      <view wx:if="{{isMerchant}}" class="btn-common" bindtap="onShopTap">
        <text>我的店铺</text>
      </view>
      
      <!-- 成为商户按钮（普通用户） -->
      <view wx:else class="btn-common" bindtap="onJoinTap">
        <text>成为商户</text>
      </view>
      
      <!-- 购买响应包按钮 -->
      <view wx:if="{{isMerchant}}" class="btn-common" bindtap="onBuyTap">
        <text>购买响应包</text>
      </view>
    </view>
    
    <!-- 第二行按钮 -->
    <view class="button-row">
      <!-- 客服按钮 -->
      <view class="btn-common">
        <button open-type="contact" class="contact-btn-common">在线客服</button>
      </view>
      
      <!-- 意见反馈按钮 -->
      <view class="btn-common" bindtap="onFeedbackTap">
        <text>意见反馈</text>
      </view>
    </view>
  </view>
</view>
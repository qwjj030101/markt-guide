.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.user-info {
  padding: 30rpx 0;
  text-align: left;
  background: linear-gradient(135deg, #4caf50 0%, #81c784 100%);
  color: white;
  border-bottom-left-radius: 30rpx;
  border-bottom-right-radius: 30rpx;
  margin-bottom: 30rpx;
}

/* 用户信息容器 */
.user-info-container {
  display: flex;
  align-items: center;
  padding: 0 40rpx;
  position: relative;
}

/* 更多操作按钮 */
.more-btn {
  position: absolute;
  top: 20rpx;
  right: 30rpx;
  font-size: 36rpx;
  color: white;
  cursor: pointer;
  z-index: 10;
}

/* 头像容器 */
.user-avatar-container {
  margin-right: 30rpx;
  position: relative;
}

/* 昵称容器 */
.user-nickname-container {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  flex: 1;
  min-width: 0;
}

/* 用户昵称 */
.user-nickname {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

/* 昵称编辑提示 */
.nickname-edit {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  cursor: pointer;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
}

.user-days {
  font-size: 24rpx;
  line-height: 1.4;
  margin-bottom: 4rpx;
}

.user-nickname {
  font-size: 32rpx;
  color: white;
}



.action-buttons {
  padding: 20rpx;
}

/* 按钮行容器 */
.button-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

/* 通用按钮样式 */
.btn-common {
  flex: 1;
  padding: 30rpx;
  border-radius: 10rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  color: white;
  background-color: #3cc51f;
  margin: 0 10rpx;
}

/* 通用按钮激活状态 */
.btn-common:active {
  opacity: 0.8;
}

/* 客服按钮 */
.contact-btn-common {
  background-color: #3cc51f;
  color: white;
  border-radius: 10rpx;
  padding: 30rpx;
  font-size: 32rpx;
  border: none;
  width: 100%;
  height: 100%;
  display: flex;
  justify-content: center;
  align-items: center;
}

/* 客服按钮激活状态 */
.contact-btn-common:active {
  opacity: 0.8;
}
/* 授权引导样式 */
.authorize-guide {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 20rpx;
}

.default-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
  background-color: #f0f0f0;
}

.guide-text {
  font-size: 28rpx;
  color: white;
  margin-bottom: 10rpx;
  text-align: center;
}

.guide-subtext {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 30rpx;
  text-align: center;
}

.authorize-btn {
  background: rgba(255, 255, 255, 0.9);
  color: #4caf50;
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-top: 10rpx;
}

.authorize-btn:active {
  opacity: 0.8;
}


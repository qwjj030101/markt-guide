/* 主容器 */
.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 搜索栏 */
.search-bar {
  padding: 20rpx;
  background-color: #fff;
}

/* 搜索输入框 */
.search-bar input {
  width: 100%;
  height: 70rpx;
  background-color: #f0f0f0;
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

/* 轮播图区域 */
.banner {
  height: 300rpx;
  margin-bottom: 20rpx;
}

/* 轮播组件 */
.banner swiper {
  width: 100%;
  height: 100%;
}

/* 轮播图片 */
.banner image {
  width: 100%;
  height: 100%;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

/* 筛选项 */
.filter-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20rpx;
  font-size: 28rpx;
}

/* 商店列表 */
.shop-list {
  padding: 20rpx;
}

/* 商店列表项 */
.shop-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
}

/* 商店头像 */
.shop-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

/* 商店名称 */
.shop-name {
  font-size: 32rpx;
  color: #333;
}
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <view class="nav-left" bindtap="onCancel">
      <text>取消</text>
    </view>
    <view class="nav-title">编辑商铺</view>
    <view class="nav-right" bindtap="onSubmit">
      <text class="submit-btn">保存</text>
    </view>
  </view>

  <!-- 表单内容 -->
  <view class="form-container">
    <!-- 头像上传 -->
    <view class="form-item">
      <text class="label">商铺头像</text>
      <view class="avatar-upload">
        <image class="avatar" src="{{shopInfo.avatar || '/images/R.jpg'}}" mode="aspectFill"></image>
        <view class="upload-btn" bindtap="chooseAvatar">
          <text>更换头像</text>
        </view>
      </view>
    </view>

    <!-- 商铺名称 -->
    <view class="form-item">
      <text class="label">商铺名称</text>
      <input 
        class="input" 
        placeholder="请输入商铺名称" 
        value="{{shopInfo.name}}" 
        bindinput="onNameChange"
      />
    </view>

    <!-- 联系电话 -->
    <view class="form-item">
      <text class="label">联系电话</text>
      <input 
        class="input" 
        placeholder="请输入联系电话" 
        value="{{shopInfo.phone}}" 
        bindinput="onPhoneChange"
        type="number"
      />
    </view>

    <!-- 商铺地址 -->
    <view class="form-item">
      <text class="label">商铺地址</text>
      <input 
        class="input address" 
        placeholder="请选择地址" 
        value="{{shopInfo.address}}" 
        bindinput="onAddressChange"
      />
      <view class="address-buttons">
        <button class="address-btn" bindtap="chooseLocation">地图选点</button>
        <button class="address-btn" bindtap="getCurrentLocation">获取当前位置</button>
      </view>
    </view>

    <!-- 商铺简介 -->
    <view class="form-item">
      <text class="label">商铺简介</text>
      <textarea 
        class="textarea" 
        placeholder="请输入商铺简介" 
        value="{{shopInfo.description}}" 
        bindinput="onDescriptionChange"
        auto-height
      ></textarea>
    </view>

    <!-- 营业时间 -->
    <view class="form-item">
      <text class="label">营业时间</text>
      <input 
        class="input" 
        placeholder="如：09:00-18:00" 
        value="{{shopInfo.businessHours}}" 
        bindinput="onBusinessHoursChange"
      />
    </view>
  </view>
</view>
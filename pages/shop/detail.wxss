.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.shop-card {
  position: relative;
  height: 400rpx;
  overflow: hidden;
}

.shop-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  filter: blur(20rpx);
}
/* 背景图样式 */
.bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-size: cover;
  background-position: center;
  
}

/* 模糊背景样式 */
.bg-blur {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.2);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

/* 商铺信息样式 */

.shop-info {
  position: relative;
  z-index: 1;
  padding: 40rpx;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.7));
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

/* 商铺名称样式 */
.shop-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 30rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.8);
}

/* 商铺详情样式 */
.shop-details {
  margin-bottom: 20rpx;
}

/* 详情项样式 */
.detail-item {
  display: block;
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 15rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.8);
}

/* 详情标签样式 */
.detail-label {
  opacity: 0.8;
}

/* 详情值样式 */
.detail-value {
  font-weight: 500;
}


.shop-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 30rpx;
}

.shop-detail {
  margin-bottom: 20rpx;
}




/* 电话和地址可点击样式 */
.detail-item[bindtap] {
  cursor: pointer;
  transition: all 0.3s ease;
  position: relative;
  display: inline-block;
  padding: 5rpx 0;
  border-bottom: 1rpx solid transparent; /* 初始状态：透明边框 */

}

.detail-item[bindtap]:hover {
  color: #4CAF50;
  border-bottom: 1rpx solid #4CAF50; /* 悬停时：绿色边框 */
}

/* 可点击元素下方添加细微下划线 */
.detail-item[bindtap]::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 0;
  height: 1rpx;
  background-color: #4CAF50;
  transition: width 0.3s ease;
  z-index: -1; /* 确保下划线在文字之下 */
}

/* 悬停时显示下划线 */
.detail-item[bindtap]:hover::after {
  width: 100%;
}

/* 商品网格样式 */
.products-section {
  padding: 20rpx;
  background-color: #f5f5f5;
}

.products-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.products-grid .product-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 10rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  padding: 20rpx;
}

.products-grid .product-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.products-grid .product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.products-grid .product-image image {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
}

.products-grid .product-name {
  font-size: 30rpx;
  color: #333;
  flex: 1;
  line-height: 1.4;
}

/* 空状态提示 */
.empty-tip {
  grid-column: 1 / -1;
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}


.label {
  opacity: 0.8;
}

.value {
  font-weight: 500;
}

.shop-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
}

.product-list {
  padding: 20rpx;
  background-color: #f5f5f5;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding: 0 10rpx;
}

.product-item {
  display: flex;
  align-items: center;
  background-color: #fff;
  padding: 20rpx;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
}

.product-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 10rpx;
  margin-right: 20rpx;
}

.product-name {
  font-size: 30rpx;
  color: #333;
}
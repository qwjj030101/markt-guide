.container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 30rpx;
  background-color: #fff;
  margin-bottom: 20rpx;
}

.user-avatar {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  margin-bottom: 20rpx;
}

.user-nickname {
  font-size: 32rpx;
  color: #333;
}

.action-buttons {
  padding: 20rpx;
}

.btn-shop,
.btn-renew,
.btn-join {
  background-color: #fff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 10rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  color: #333;
}

.btn-shop {
  flex-direction: column;
}

.btn-shop .btn-text {
  font-size: 32rpx;
  margin-bottom: 10rpx;
}

.btn-shop .btn-days {
  font-size: 24rpx;
  color: #3cc51f;
}

.btn-renew,
.btn-join {
  background-color: #3cc51f;
  color: #fff;
}
.detail-container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.demand-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.user-nickname {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.demand-content {
  padding: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  font-size: 28rpx;
  line-height: 1.5;
  color: #333;
  margin-bottom: 20rpx;
  white-space: pre-wrap;
}

.demand-image {
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  position: relative;
}

.demand-image image {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

.preview-tip {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: rgba(0, 0, 0, 0.5);
  color: #fff;
  text-align: center;
  padding: 12rpx;
  font-size: 24rpx;
}

.demand-status {
  margin-bottom: 20rpx;
  padding: 12rpx 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.status-text {
  font-size: 24rpx;
  color: #666;
}

.response-section {
  margin-bottom: 40rpx;
  padding: 20rpx;
  background-color: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.response-list {
  margin-top: 16rpx;
}

.response-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
  padding: 12rpx;
  background-color: #f9f9f9;
  border-radius: 8rpx;
}

.response-avatar {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.response-remark {
  flex: 1;
  font-size: 24rpx;
  line-height: 1.4;
  color: #666;
  word-break: break-word;
}

.no-response {
  padding: 40rpx 0;
  text-align: center;
  color: #999;
  font-size: 24rpx;
}

.action-buttons {
  display: flex;
  justify-content: center;
  margin-top: 20rpx;
  margin-bottom: 40rpx;
}

.btn-complete,
.btn-respond {
  width: 200rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 40rpx;
  margin: 0 20rpx;
}

.btn-complete {
  background-color: #4CAF50;
  color: #fff;
}

.btn-respond {
  background-color: #2196F3;
  color: #fff;
}

.btn-disabled {
  background-color: #ccc !important;
  color: #fff !important;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .demand-image image {
    height: 300rpx;
  }
  
  .btn-complete,
  .btn-respond {
    width: 180rpx;
    height: 70rpx;
    line-height: 70rpx;
    font-size: 26rpx;
  }
}
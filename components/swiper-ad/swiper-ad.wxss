.swiper-container {
  width: 100%;
  height: 300rpx;
  position: relative;
}

.swiper-image {
  width: 100%;
  height: 100%;
  border-radius: 10rpx;
}

/* 指示器样式 */
.swiper-container .wx-swiper-dots {
  bottom: 20rpx;
}

.swiper-container .wx-swiper-dot {
  width: 12rpx;
  height: 12rpx;
  margin: 0 8rpx;
  background-color: rgba(255, 255, 255, 0.6);
  border-radius: 50%;
}

.swiper-container .wx-swiper-dot-active {
  background-color: #ffffff;
  width: 30rpx;
  border-radius: 6rpx;
}